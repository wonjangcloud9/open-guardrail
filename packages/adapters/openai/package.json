{
  "name": "open-guardrail-openai",
  "version": "1.9.0",
  "description": "OpenAI SDK adapter for open-guardrail — 215+ guards for chat completions input/output, prompt injection, PII, toxicity & more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "open-guardrail-core": "workspace:*"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.1.0"
  },
  "author": "Lucas <wonjangcloud9@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonjangcloud9/open-guardrail",
    "directory": "packages/adapters/openai"
  },
  "bugs": "https://github.com/wonjangcloud9/open-guardrail/issues",
  "homepage": "https://github.com/wonjangcloud9/open-guardrail#readme",
  "engines": { "node": ">=18" },
  "keywords": ["guardrail", "open-guardrail", "openai", "chatgpt", "gpt", "gpt-4", "llm", "ai-safety", "content-filter", "moderation", "prompt-injection", "pii", "pii-detection", "toxicity", "middleware", "input-validation", "output-validation", "safety", "ai-guardrail", "text-moderation"],
  "license": "MIT"
}
