{
  "name": "open-guardrail",
  "version": "1.5.1",
  "description": "Open-source guardrail engine for LLM apps — 38 guards, 7 adapters, streaming pipeline, risk routing, plugin system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "open-guardrail-core": "workspace:*",
    "open-guardrail-guards": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.1.0"
  },
  "author": "Lucas <wonjangcloud9@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonjangcloud9/open-guardrail"
  },
  "bugs": "https://github.com/wonjangcloud9/open-guardrail/issues",
  "homepage": "https://github.com/wonjangcloud9/open-guardrail#readme",
  "engines": { "node": ">=18" },
  "keywords": ["guardrail", "llm", "ai", "safety", "moderation", "pii", "prompt-injection", "content-filter", "compliance", "isms-p", "openai", "anthropic", "claude", "korean"],
  "license": "MIT"
}
