{
  "name": "open-guardrail",
  "version": "0.2.0",
  "description": "Open-source guardrail engine for LLM applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "open-guardrail-core": "^0.1.0",
    "open-guardrail-guards": "^0.2.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0"
  },
  "keywords": ["guardrail", "llm", "ai", "safety", "moderation", "pii", "prompt-injection"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonjangcloud9/open-guardrail"
  }
}
