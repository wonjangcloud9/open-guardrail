{
  "name": "open-guardrail-guards",
  "version": "1.4.4",
  "description": "38 built-in guards for LLM safety: PII, prompt injection, toxicity, bias, API key detection, encoding attack, Korean ISMS-P/PIPA, EU AI Act",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
