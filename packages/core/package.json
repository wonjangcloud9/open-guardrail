{
  "name": "open-guardrail-core",
  "version": "1.3.1",
  "description": "Core engine: Pipeline, Guard interface, EventBus, Config Loader — provider agnostic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "vitest": "^3.1.0"
  },
  "author": "Lucas <wonjangcloud9@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonjangcloud9/open-guardrail",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/wonjangcloud9/open-guardrail/issues",
  "homepage": "https://github.com/wonjangcloud9/open-guardrail#readme",
  "engines": { "node": ">=18" },
  "keywords": ["guardrail", "llm", "pipeline", "guard", "event-bus", "config", "middleware"],
  "license": "MIT"
}
