{
  "name": "open-guardrail-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "bench": "pnpm --filter open-guardrail-benchmarks bench",
    "playground": "pnpm --filter open-guardrail-playground dev",
    "docs:dev": "pnpm --filter open-guardrail-docs dev",
    "docs:build": "pnpm --filter open-guardrail-docs build",
    "test:coverage": "pnpm --filter open-guardrail-core test:coverage && pnpm --filter open-guardrail-guards test:coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
